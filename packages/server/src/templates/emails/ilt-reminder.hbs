<table role="presentation" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td style="padding-bottom: 24px;">
      <h1 style="margin: 0 0 8px; font-size: 22px; font-weight: 600; color: #202124;">Upcoming Training Session</h1>
      <p style="margin: 0; font-size: 15px; color: #5f6368; line-height: 1.5;">Hi {{name}},</p>
    </td>
  </tr>
  <tr>
    <td style="padding-bottom: 24px;">
      <p style="margin: 0 0 16px; font-size: 15px; color: #3c4043; line-height: 1.6;">
        This is a reminder about your upcoming instructor-led training session. Please make sure to attend on time.
      </p>
      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #e8eaf6; border-radius: 8px; border-left: 4px solid #3949ab;">
        <tr>
          <td style="padding: 16px 20px;">
            <p style="margin: 0 0 4px; font-size: 12px; font-weight: 600; color: #3949ab; text-transform: uppercase; letter-spacing: 0.5px;">Session Details</p>
            <p style="margin: 0 0 12px; font-size: 18px; font-weight: 600; color: #202124;">{{sessionTitle}}</p>
            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                <td style="padding: 4px 0;">
                  <span style="font-size: 13px; color: #5f6368;">Date &amp; Time:</span>
                  <span style="font-size: 13px; font-weight: 600; color: #202124; margin-left: 8px;">{{startTime}}</span>
                </td>
              </tr>
              {{#if location}}
              <tr>
                <td style="padding: 4px 0;">
                  <span style="font-size: 13px; color: #5f6368;">Location:</span>
                  <span style="font-size: 13px; font-weight: 600; color: #202124; margin-left: 8px;">{{location}}</span>
                </td>
              </tr>
              {{/if}}
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding-bottom: 24px; text-align: center;">
      <a href="{{actionUrl}}" style="display: inline-block; padding: 12px 32px; background: linear-gradient(135deg, #3949ab 0%, #283593 100%); color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 6px; letter-spacing: 0.3px;">View Details</a>
    </td>
  </tr>
  <tr>
    <td>
      <p style="margin: 0; font-size: 13px; color: #9aa0a6; line-height: 1.5;">
        If you are unable to attend, please notify your training coordinator as soon as possible.
      </p>
    </td>
  </tr>
</table>
