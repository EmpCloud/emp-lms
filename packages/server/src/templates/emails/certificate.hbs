<table role="presentation" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td style="padding-bottom: 24px; text-align: center;">
      <div style="font-size: 48px; margin-bottom: 8px;">&#128220;</div>
      <h1 style="margin: 0 0 8px; font-size: 22px; font-weight: 600; color: #202124;">Certificate Issued</h1>
      <p style="margin: 0; font-size: 15px; color: #5f6368; line-height: 1.5;">Hi {{name}},</p>
    </td>
  </tr>
  <tr>
    <td style="padding-bottom: 24px;">
      <p style="margin: 0 0 16px; font-size: 15px; color: #3c4043; line-height: 1.6;">
        Your certificate has been issued for completing the course. You can download it at any time from your profile.
      </p>
      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #fff8e1; border-radius: 8px; border-left: 4px solid #f9a825;">
        <tr>
          <td style="padding: 16px 20px;">
            <p style="margin: 0 0 4px; font-size: 12px; font-weight: 600; color: #f57f17; text-transform: uppercase; letter-spacing: 0.5px;">Certificate Details</p>
            <p style="margin: 0 0 8px; font-size: 18px; font-weight: 600; color: #202124;">{{courseName}}</p>
            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                <td style="padding: 4px 0;">
                  <span style="font-size: 13px; color: #5f6368;">Certificate Number:</span>
                  <span style="font-size: 13px; font-weight: 600; color: #202124; margin-left: 8px;">{{certificateNumber}}</span>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding-bottom: 24px; text-align: center;">
      <a href="{{actionUrl}}" style="display: inline-block; padding: 12px 32px; background: linear-gradient(135deg, #f9a825 0%, #f57f17 100%); color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 6px; letter-spacing: 0.3px;">Download Certificate</a>
    </td>
  </tr>
  <tr>
    <td>
      <p style="margin: 0; font-size: 13px; color: #9aa0a6; line-height: 1.5;">
        Your certificate can be verified online using the certificate number above.
      </p>
    </td>
  </tr>
</table>
