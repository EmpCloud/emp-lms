<table role="presentation" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td style="padding-bottom: 24px;">
      <h1 style="margin: 0 0 8px; font-size: 22px; font-weight: 600; color: #202124;">Compliance Training Reminder</h1>
      <p style="margin: 0; font-size: 15px; color: #5f6368; line-height: 1.5;">Hi {{name}},</p>
    </td>
  </tr>
  <tr>
    <td style="padding-bottom: 24px;">
      <p style="margin: 0 0 16px; font-size: 15px; color: #3c4043; line-height: 1.6;">
        This is a reminder that your required compliance training is due soon. Please complete it before the deadline to stay compliant.
      </p>
      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #fff3e0; border-radius: 8px; border-left: 4px solid #ef6c00;">
        <tr>
          <td style="padding: 16px 20px;">
            <p style="margin: 0 0 4px; font-size: 12px; font-weight: 600; color: #ef6c00; text-transform: uppercase; letter-spacing: 0.5px;">Required Training</p>
            <p style="margin: 0 0 8px; font-size: 18px; font-weight: 600; color: #202124;">{{courseName}}</p>
            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                <td style="padding: 4px 0;">
                  <span style="font-size: 13px; color: #5f6368;">Due Date:</span>
                  <span style="display: inline-block; padding: 2px 10px; background-color: #ef6c00; color: #ffffff; font-size: 13px; font-weight: 600; border-radius: 4px; margin-left: 8px;">{{dueDate}}</span>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding-bottom: 24px; text-align: center;">
      <a href="{{actionUrl}}" style="display: inline-block; padding: 12px 32px; background: linear-gradient(135deg, #ef6c00 0%, #e65100 100%); color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 6px; letter-spacing: 0.3px;">Complete Training</a>
    </td>
  </tr>
  <tr>
    <td>
      <p style="margin: 0; font-size: 13px; color: #9aa0a6; line-height: 1.5;">
        If you have already completed this training, please disregard this reminder. Contact your administrator if you need assistance.
      </p>
    </td>
  </tr>
</table>
