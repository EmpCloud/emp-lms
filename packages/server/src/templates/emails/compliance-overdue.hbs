<table role="presentation" cellpadding="0" cellspacing="0" width="100%">
  <tr>
    <td style="padding-bottom: 24px;">
      <h1 style="margin: 0 0 8px; font-size: 22px; font-weight: 600; color: #c62828;">Overdue: Compliance Training Required</h1>
      <p style="margin: 0; font-size: 15px; color: #5f6368; line-height: 1.5;">Hi {{name}},</p>
    </td>
  </tr>
  <tr>
    <td style="padding-bottom: 24px;">
      <p style="margin: 0 0 16px; font-size: 15px; color: #3c4043; line-height: 1.6;">
        Your required compliance training is now overdue. Please complete it as soon as possible to avoid non-compliance.
      </p>
      <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="background-color: #ffebee; border-radius: 8px; border-left: 4px solid #c62828;">
        <tr>
          <td style="padding: 16px 20px;">
            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                <td>
                  <span style="display: inline-block; padding: 2px 10px; background-color: #c62828; color: #ffffff; font-size: 11px; font-weight: 700; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.5px;">Overdue</span>
                </td>
              </tr>
            </table>
            <p style="margin: 8px 0 4px; font-size: 12px; font-weight: 600; color: #c62828; text-transform: uppercase; letter-spacing: 0.5px;">Required Training</p>
            <p style="margin: 0 0 8px; font-size: 18px; font-weight: 600; color: #202124;">{{courseName}}</p>
            <table role="presentation" cellpadding="0" cellspacing="0" width="100%">
              <tr>
                <td style="padding: 4px 0;">
                  <span style="font-size: 13px; color: #5f6368;">Original Due Date:</span>
                  <span style="font-size: 13px; font-weight: 600; color: #c62828; margin-left: 8px;">{{dueDate}}</span>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <tr>
    <td style="padding-bottom: 24px; text-align: center;">
      <a href="{{actionUrl}}" style="display: inline-block; padding: 12px 32px; background: linear-gradient(135deg, #c62828 0%, #b71c1c 100%); color: #ffffff; font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 6px; letter-spacing: 0.3px;">Complete Now</a>
    </td>
  </tr>
  <tr>
    <td>
      <p style="margin: 0; font-size: 13px; color: #9aa0a6; line-height: 1.5;">
        If you need assistance or have questions about this requirement, please contact your administrator immediately.
      </p>
    </td>
  </tr>
</table>
