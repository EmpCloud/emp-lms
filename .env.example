NODE_ENV=development
PORT=4500
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:5178

# LMS Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=emp_lms
DB_POOL_MIN=2
DB_POOL_MAX=10

# EmpCloud Master Database
EMPCLOUD_DB_HOST=localhost
EMPCLOUD_DB_PORT=3306
EMPCLOUD_DB_USER=root
EMPCLOUD_DB_PASSWORD=
EMPCLOUD_DB_NAME=empcloud

# Redis (for BullMQ job queues)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email (SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=lms@empcloud.com
SMTP_FROM_NAME=EmpCloud LMS

# File Uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=500
MAX_VIDEO_SIZE_MB=2048

# SCORM
SCORM_STORAGE_DIR=./uploads/scorm

# AI Recommendations (optional)
OPENAI_API_KEY=
AI_PROVIDER=none

# emp-rewards integration (optional)
REWARDS_API_URL=http://localhost:4600/api/v1
REWARDS_API_KEY=
